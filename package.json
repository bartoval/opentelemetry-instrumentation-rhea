{
  "name": "opentelemetry-instrumentation-rhea",
  "version": "0.1.0",
  "description": "OpenTelemetry auto-instrumentation for rhea AMQP 1.0 client",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/bartoval/opentelemetry-instrumentation-rhea"
  },
  "author": "bartoval",
  "license": "Apache-2.0",
  "keywords": [
    "opentelemetry",
    "rhea",
    "amqp",
    "amqp10",
    "amqp 1.0",
    "instrumentation",
    "tracing",
    "observability"
  ],
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf build",
    "test": "mocha",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" && eslint --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" && eslint",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0"
  },
  "dependencies": {
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "express": "^5.0.0",
    "mocha": "^11.0.0",
    "prettier": "^3.0.0",
    "rhea": "^3.0.0",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "files": [
    "build/src/**/*.js",
    "build/src/**/*.d.ts",
    "LICENSE",
    "README.md"
  ]
}
